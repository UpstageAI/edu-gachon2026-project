# ── 데이터베이스 (Supabase) ───────────────────────────────
# text2sql_reader 계정(읽기 전용)의 Session Pooler 연결 문자열
# 반드시 Pooler 주소 사용 (Direct connection은 IPv6 전용이라 로컬에서 접속 실패할 수 있음)
SUPABASE_DB_URL=postgresql://text2sql_reader.<project-ref>:<비밀번호>@aws-0-ap-northeast-1.pooler.supabase.com:5432/postgres

# ── AI agent (teammate의 aiagent 서비스) ──────────────────
# 로컬에서 agent를 기본 포트로 띄웠다면 생략해도 됨 (코드 기본값과 동일).
# docker-compose 등으로 agent가 다른 호스트/포트에서 뜨면 이 값으로 덮어쓰기.
AI_AGENT_BASE_URL=http://localhost:8000

# ── 백엔드 서버 설정 ───────────────────────────────────────
PORT=8080

# ── CORS 허용 origin (콤마로 구분, 선택사항) ───────────────
# 안 넣으면 기본값(배포된 프론트엔드 URL + http://localhost:5173) 사용.
# CORS_ALLOWED_ORIGINS=https://text2sql-frontend-bfkt3wk5mq-du.a.run.app,http://localhost:5173
