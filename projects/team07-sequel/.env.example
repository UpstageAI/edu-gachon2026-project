# ── LLM (Upstage / LiteLLM) ──
UPSTAGE_API_KEY=

# ── 난이도별 모델 라우팅 (미설정 시 settings.py 기본값) ──
# 정확도 최우선 정책: 라우팅 그리드(docs/실험_총정리.md §7-4)에서 전 난이도 pro2|k8 이 최고.
MODEL_EASY=solar-pro2
MODEL_MEDIUM=solar-pro2
MODEL_HARD=solar-pro2
MODEL_EXTRA_HARD=solar-pro2

# ── 대상 DB: Supabase(PostgreSQL) 읽기 전용 ──
# text2sql_reader 계정(읽기 전용)의 Session Pooler 연결 문자열.
# 반드시 Pooler 주소 사용 (Direct connection은 IPv6 전용이라 로컬에서 접속 실패할 수 있음).
SUPABASE_DB_URL=postgresql://text2sql_reader.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres

# ── 실행 가드레일 ──
SQL_MAX_ROWS=1000
SQL_EXEC_TIMEOUT_S=5
AGENT_MAX_RETRIES=2

# ── Langfuse (트레이싱) ──
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# ── CORS (콤마 구분, React dev 기본) ──
CORS_ORIGINS=["http://localhost:5173"]
