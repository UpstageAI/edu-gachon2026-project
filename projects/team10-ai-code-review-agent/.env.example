# 이 파일은 서버 VM의 ~/ai-code-review-agent-deploy/.env 또는 로컬 개발용 .env의 예시다.
# GitHub Actions 배포 workflow가 읽는 값은 아래 "GitHub Actions 설정" 섹션을 참고해
# GitHub Repository Variables/Secrets에 넣고, 이 .env 파일에는 넣지 않는다.

################################################################################
# GitHub Actions 설정: GitHub Repository Variables에 등록, 서버 .env에 넣지 않음
################################################################################
# GCP_PROJECT_ID=<GCP Project ID>
# GCP_ZONE=<VM zone, 예: asia-northeast3-c>
# GCE_INSTANCE=<GCE VM instance name, 예: ai-code-review-agent>
# AI_REVIEWER_IMAGE_NAME=ai-code-review-agent-api
#
# CD_DEPLOY_TARGET 모드:
# - gcp-vm: main CI 성공 후 image를 빌드하고 GCP VM까지 자동 배포한다.
# - local-only: image build만 검증하고 GCP VM 배포는 건너뛴다.
# CD_DEPLOY_TARGET=gcp-vm

################################################################################
# GitHub Actions 설정: GitHub Repository Secrets에 등록, 서버 .env에 넣지 않음
################################################################################
# GCP_WORKLOAD_IDENTITY_PROVIDER=projects/<PROJECT_NUMBER>/locations/global/workloadIdentityPools/<POOL_ID>/providers/<PROVIDER_ID>
# GCP_SERVICE_ACCOUNT=github-deployer@<PROJECT_ID>.iam.gserviceaccount.com
#
# 주의: UPSTAGE_API_KEY, GITHUB_APP_PRIVATE_KEY, LANGFUSE_SECRET_KEY 같은 앱 런타임
# 비밀값은 현재 CD workflow가 GitHub Secrets에서 VM으로 전달하지 않는다.
# 이 값들은 아래 서버 .env 섹션에 넣거나, 별도 Secret Manager 주입 로직을 구현해야 한다.

################################################################################
# 서버/로컬 공통 실행 설정: VM .env 또는 로컬 .env에 들어가는 값
################################################################################

# APP_ENV는 환경 표시용 값이다. 현재 핵심 기능 분기는 크지 않지만 로그/운영 구분에 사용한다.
# 권장값: local, staging, production
APP_ENV=local

# FastAPI가 컨테이너 안에서 listen할 포트다. Caddy APP_PORT도 이 값을 따라간다.
PORT=8080

# COMPOSE_FILE 모드:
# - docker-compose.yml: VM 배포처럼 이미 빌드된 image만 실행한다.
# - docker-compose.yml:docker-compose.local.yml: 로컬에서 Dockerfile을 직접 build한다.
# VM에서는 반드시 docker-compose.yml만 사용한다.
COMPOSE_FILE=docker-compose.yml:docker-compose.local.yml

# AI_REVIEWER_IMAGE는 compose가 실행할 api image다.
# 로컬 build 테스트에서는 ai-code-review-agent:local을 사용한다.
# VM 배포에서는 GitHub Actions가 배포 시점에 이 값을 주입하므로 .env에 고정하지 않아도 된다.
AI_REVIEWER_IMAGE=ai-code-review-agent:local

# COMPOSE_PROFILES 모드:
# - 빈 값: api + postgres만 실행한다. 로컬 일반 테스트 기본값.
# - edge: caddy reverse proxy/TLS까지 실행한다. 서버 VM 운영 권장값.
# edge 사용 시 DOMAIN이 반드시 필요하다.
COMPOSE_PROFILES=

# DOMAIN은 Caddy가 80/443에서 받아 자동 HTTPS 인증서를 발급받을 도메인이다.
# 실제 도메인이 없다면 정적 IP 기반 sslip.io 도메인을 쓸 수 있다.
# 예: 정적 IP 34.64.123.45 -> DOMAIN=34-64-123-45.sslip.io
DOMAIN=

################################################################################
# API 인증 / GitHub 게시 설정: 서버 .env에 들어가는 런타임 값
################################################################################

# 내부 API 보호용 Bearer token이다. /v1/reviews, policy sync 등에 사용된다.
# 로컬 데모에서는 change-me도 가능하지만 서버에서는 openssl rand -base64 32 등으로 만든다.
AI_REVIEWER_TOKEN=change-me

# PUBLISH_MODE 모드:
# - local: .local-data/comments 아래에 Markdown 댓글 파일만 저장한다. 로컬 smoke test용.
# - github: GITHUB_TOKEN(PAT)으로 PR issue comment를 작성한다. GitHub App이 없을 때의 fallback.
# - github_app: webhook payload의 installation id로 GitHub App token을 발급해 댓글/check를 작성한다. 서버 운영 권장값.
PUBLISH_MODE=local

# PUBLISH_MODE=github일 때만 필요한 PAT다. PUBLISH_MODE=github_app이면 비운다.
# 이 값은 GitHub Actions secret이 아니라, 해당 모드로 서버를 실행할 때 서버 .env에 들어가는 값이다.
GITHUB_TOKEN=

################################################################################
# GitHub App + Webhook 설정: 서버 .env에 들어가는 런타임 값
################################################################################

# GitHub App webhook URL은 https://<DOMAIN>/v1/github/webhooks 로 설정한다.
# GitHub App의 Webhook secret 칸에 넣은 값과 동일해야 한다.
GITHUB_WEBHOOK_SECRET=

# GITHUB_WEBHOOK_REVIEW_MODE 모드:
# - after_checks: CI/check_suite 완료 이후 리뷰한다. 기본 운영 권장값.
# - pull_request: PR opened/synchronize 이벤트만으로 즉시 리뷰한다. CI 없는 데모 repo용.
# - all: PR 이벤트와 check 완료 이벤트를 모두 처리한다. 테스트/디버그용이며 중복 리뷰에 주의한다.
GITHUB_WEBHOOK_REVIEW_MODE=after_checks

# GitHub PR Checks 화면에 표시될 check run 이름이다.
# Branch protection에서 Required status check 이름과 같아야 한다.
GITHUB_CHECK_RUN_NAME=AI Code Review

# GitHub App 설정 화면의 App ID다. client id가 아니라 숫자 App ID를 넣는다.
GITHUB_APP_ID=

# GitHub App private key다. 서버 .env에는 한 줄 base64 PEM 사용을 권장한다.
# 원문 PEM을 직접 넣을 수도 있지만 줄바꿈/공백 처리 실수가 잦다.
GITHUB_APP_PRIVATE_KEY=

# private key를 파일로 mount해 쓸 때만 사용한다. 현재 기본 compose는 별도 key 파일을 mount하지 않으므로 보통 비운다.
GITHUB_APP_PRIVATE_KEY_PATH=

# GitHub Enterprise가 아니면 기본값을 유지한다.
GITHUB_API_BASE_URL=https://api.github.com

################################################################################
# LLM / Observability 설정: 서버 .env에 들어가는 런타임 값
################################################################################

# LLM_MODE 모드:
# - litellm: LiteLLM을 통해 Upstage Solar3 API를 실제 호출한다. 서버 운영 기본값.
# - mock: 외부 API 없이 deterministic reviewer를 사용한다. 로컬/CI smoke test용.
LLM_MODE=litellm

# Upstage API key다. LLM_MODE=litellm이면 필수다.
UPSTAGE_API_KEY=
UPSTAGE_API_BASE_URL=https://api.upstage.ai/v1

# Solar3는 모델명을 나누지 않고 같은 model에 reasoning_effort만 다르게 전달한다.
SOLAR3_MODEL=solar-pro3

# reasoning_effort 값:
# - low: 실패한 문법/린트/테스트 원인을 빠르게 확인하는 리뷰
# - medium: CI 통과 후 RAG 정책/표기 규칙을 반영하는 표준 리뷰
# - high: 사용자가 GitHub Checks 버튼으로 요청하는 선택적 심층 리뷰
SOLAR3_LOW_REASONING_EFFORT=low
SOLAR3_MEDIUM_REASONING_EFFORT=medium
SOLAR3_HIGH_REASONING_EFFORT=high

# Solar3 생성 토큰 상한이다. reasoning token도 이 예산을 사용할 수 있으므로 표준/심층 리뷰는
# 과거 4,000보다 여유 있게 둔다. 입력 토큰과 이 값의 합은 모델 context 이하여야 한다.
SOLAR3_LOW_MAX_TOKENS=4096
SOLAR3_MEDIUM_MAX_TOKENS=8192
SOLAR3_HIGH_MAX_TOKENS=16384

# 서비스가 신뢰하는 diff 분석 script, skill manifest와 skill 문서가 있는 경로다.
# 저장소에서 가져온 임의 script는 실행하지 않는다. Docker에서는 compose가 /app 경로를 주입한다.
REVIEW_HARNESS_ROOT=review_harness

# Langfuse observability 설정이다.
# public/secret key를 모두 채우면 LiteLLM 호출의 모델, token, cost, latency, metadata가 기록된다.
# 둘 중 하나라도 비우면 Langfuse 연동은 비활성화된다.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

################################################################################
# 저장소 / RAG / DB 설정: 서버 .env에 들어가는 런타임 값
################################################################################

# STORAGE_BACKEND 모드:
# - postgres: 리뷰 이력을 Postgres에 저장한다. 서버 운영 권장값.
# - local: REVIEW_STORE_PATH JSON 파일에 저장한다. 로컬 fallback용.
STORAGE_BACKEND=postgres

# RAG_BACKEND 모드:
# - postgres: pgvector/Postgres 테이블에 정책 chunk를 저장하고 검색한다. 서버 운영 권장값.
# - local: POLICY_ROOT 파일을 직접 읽어 keyword 기반으로 검색한다. 로컬 fallback용.
RAG_BACKEND=postgres

POSTGRES_DB=reviewer
POSTGRES_USER=reviewer

# 서버에서는 반드시 강한 값으로 바꾼다. 기존 volume 생성 후 바꾸면 DB 인증 문제가 날 수 있다.
POSTGRES_PASSWORD=reviewer

# compose 내부 서비스명 postgres를 host로 사용한다.
DATABASE_URL=postgresql://reviewer:reviewer@postgres:5432/reviewer

# host에 노출할 Postgres 포트다. 서버 방화벽에서 5432를 외부 공개하지 않는다.
POSTGRES_PORT=5432

################################################################################
# 로컬 CLI fallback 경로
################################################################################

# docker compose 실행 시에는 docker-compose.yml이 컨테이너 내부 경로(/app/...)를 주입한다.
# 아래 값은 compose 밖에서 python CLI를 직접 실행할 때 쓰는 로컬 fallback 경로다.
POLICY_ROOT=policies
LOCAL_DATA_DIR=.local-data
REVIEW_STORE_PATH=.local-data/reviews.json
COMMENT_OUTPUT_DIR=.local-data/comments
