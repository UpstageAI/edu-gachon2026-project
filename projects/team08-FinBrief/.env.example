APP_NAME=FinBrief
APP_VERSION=0.1.0
APP_ENV=local
API_V1_PREFIX=/api/v1
LOG_LEVEL=INFO
DEFAULT_TIMEZONE=Asia/Seoul
ENABLE_MOCK_DATA=true
SERVICE_PORT=8000
APP_IMAGE=finbrief:local

SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_SCHEMA=public

LITELLM_MODEL=upstage/solar-pro
LITELLM_FALLBACK_MODEL=
LITELLM_PROXY_URL=
LITELLM_MASTER_KEY=
LITELLM_GUARDRAILS=
UPSTAGE_API_KEY=
FINBRIEF_LLM_STUB=1
FINBRIEF_LLM_TIMEOUT_SECONDS=30
FINBRIEF_LLM_NUM_RETRIES=2
FINBRIEF_LLM_GUARDRAIL_ENABLED=true
FINBRIEF_LLM_REQUIRE_JSON=true
FINBRIEF_LLM_REQUIRE_DISCLAIMER=true
FINBRIEF_LLM_FORBIDDEN_TERMS=매수 추천,매도 추천,매수하세요,매도하세요,매수 타이밍,매도 타이밍,보유 추천,지금 매수,지금 매도,지금 사야,지금 팔아야,확정 수익,무조건 상승,반드시 수익,강력 추천,손실 없음,보장 수익,수익 보장,원금 보장,무조건 매수,무조건 매도
FINBRIEF_LLM_PII_MASKING=true

GEMINI_API_KEY=
FINBRIEF_IMAGE_MODEL=gemini-3.1-flash-lite-image
FINBRIEF_IMAGE_STUB=1
FINBRIEF_FONT=
FINBRIEF_REPORT_OUT=

LANGFUSE_ENABLED=false
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
LANGFUSE_BASE_URL=
LANGFUSE_OTEL_HOST=
LANGFUSE_CAPTURE_IO=true
LANGFUSE_FLUSH_ON_SHUTDOWN=false
FINBRIEF_TRACE_SALT=

FRED_API_KEY=
ECOS_API_KEY=
NEWS_RSS_URLS=

DELIVERY_DRY_RUN=true

DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
